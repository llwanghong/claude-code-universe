---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const articles = await getCollection('deepdive');
articles.sort((a, b) => a.id.localeCompare(b.id));

const titles: Record<string, string> = {
  '01-agent-loop': 'Agent 本质 + Agent Loop',
  '02-tool-system': 'Tool System 深度解剖',
  '03-todowrite-subagent': 'TodoWrite + Subagent',
  '04-skills-compaction': 'Skill Loading + Context Compaction',
  '05-tasks-background': 'Persistent Tasks + Background Tasks',
  '06-teams-protocols': 'Agent Teams + Team Protocols',
  '07-autonomous-worktree': 'Autonomous Agents + Worktree Isolation',
  '08-full-agent-summary': 'Full Agent 全景图',
};
---

<BaseLayout title="深度笔记" description="前端工程师视角的 8 篇深度学习笔记">
  <main class="max-w-4xl mx-auto px-4 md:px-8 py-12 md:py-20">
    <a href="/claude-code-universe/" class="text-sm text-[var(--color-muted)] hover:text-[var(--color-terracotta)] no-underline mb-4 inline-block">← 返回首页</a>
    <h1 class="text-3xl font-bold font-[var(--font-serif)] text-[var(--color-charcoal)] dark:text-[var(--color-cream)] mb-4">🔬 深度笔记</h1>
    <p class="text-lg text-[var(--color-muted)] mb-10">前端 Harness 工程师视角 — 三层对照学习法：教学版 vs 生产版 vs 前端启示</p>

    <div class="space-y-4">
      {articles.map(a => (
        <a href={`/claude-code-universe/deep-dive/${a.id}/`} class="block p-5 rounded-lg border border-[var(--color-border)] dark:border-[#333] hover:border-[var(--color-terracotta)] transition-colors no-underline">
          <h3 class="font-semibold text-[var(--color-charcoal)] dark:text-[var(--color-cream)] mb-1">{titles[a.id] || a.id}</h3>
          <p class="text-sm text-[var(--color-muted)]">learn-claude-code 对照 + Claude Code 生产源码 + 前端可操作启示</p>
        </a>
      ))}
    </div>
  </main>
</BaseLayout>
