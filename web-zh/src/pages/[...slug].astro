---
import { getCollection, render } from 'astro:content'
import ChapterLayout from '../layouts/ChapterLayout.astro'
import { chapters, getPartForChapter, getAdjacentChapters } from '../book.config'

export async function getStaticPaths() {
  const entries = await getCollection('chapters')
  return entries.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }))
}

const { entry } = Astro.props
const { Content, headings } = await render(entry)

// Match entry.id (e.g. "ch01-architecture") to chapter config
const chapterMeta = chapters.find(c => c.slug === entry.id)
const chapterNum = chapterMeta?.number ?? 0
const part = chapterNum ? getPartForChapter(chapterNum) : undefined
const { prev, next } = getAdjacentChapters(chapterNum)
---

<ChapterLayout
  title={chapterMeta?.title || entry.id}
  chapterNumber={chapterNum}
  slug={entry.id}
  headings={headings}
  prev={prev}
  next={next}
  part={part}
>
  <Content />
</ChapterLayout>
