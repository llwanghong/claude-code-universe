---
import BaseLayout from '../layouts/BaseLayout.astro';

const sections = [
  {
    icon: '📖', title: '架构分析',
    desc: 'Claude Code 生产级架构的完整解析。18 章，6 大抽象，从 Agent Loop 到 Swarm 协作。',
    href: '/claude-code-universe/ch01-architecture/',
    stat: '18 章 · 7 部分',
  },
  {
    icon: '🛠️', title: '动手实践',
    desc: '12 步渐进式 Python 教程。每一步只增加一个概念，从 120 行的核心循环到完整自主 Agent。',
    href: '/claude-code-universe/tutorial/',
    stat: '12 步 · 可运行代码',
  },
  {
    icon: '🔬', title: '深度笔记',
    desc: '前端 Harness 工程师视角。教学版 vs 生产版逐层对照，每个模块附前端可操作启示。',
    href: '/claude-code-universe/deep-dive/',
    stat: '8 篇 · 三层对照',
  },
  {
    icon: '📝', title: '补充资料',
    desc: '深度笔记未覆盖的主题：Bootstrap 流水线、并发执行、MCP 传输、终端 UI、性能工程。',
    href: '/claude-code-universe/supplements/',
    stat: '7 篇 · 源码对照',
  },
];
---

<BaseLayout title="Claude Code 学习宇宙" description="三份资源，一个知识体系">
  <main class="max-w-4xl mx-auto px-4 md:px-8 py-12 md:py-20">

    <!-- Hero -->
    <div class="text-center mb-16">
      <h1 class="text-4xl md:text-5xl font-bold font-[var(--font-serif)] text-[var(--color-charcoal)] dark:text-[var(--color-cream)] mb-6 leading-tight">
        Claude Code<br class="md:hidden" /> 学习宇宙
      </h1>
      <p class="text-lg text-[var(--color-secondary)] dark:text-[var(--color-muted)] max-w-2xl mx-auto leading-relaxed">
        整合三份独立资源为一个结构化知识体系，帮你从前端工程师成长为能独立设计 Agent 系统的 Harness 工程师。
      </p>
    </div>

    <!-- Four tracks -->
    <div class="grid md:grid-cols-2 gap-4 mb-16">
      {sections.map(s => (
        <a href={s.href} class="block p-6 rounded-xl border border-[var(--color-border)] dark:border-[#333] hover:border-[var(--color-terracotta)] transition-colors no-underline group">
          <div class="flex items-center gap-3 mb-3">
            <span class="text-2xl">{s.icon}</span>
            <h2 class="text-lg font-bold text-[var(--color-charcoal)] dark:text-[var(--color-cream)] group-hover:text-[var(--color-terracotta)] transition-colors">{s.title}</h2>
          </div>
          <p class="text-sm text-[var(--color-secondary)] dark:text-[var(--color-muted)] leading-relaxed mb-3">{s.desc}</p>
          <span class="text-xs font-medium text-[var(--color-terracotta)]">{s.stat}</span>
        </a>
      ))}
    </div>

    <!-- Knowledge Map -->
    <div class="mb-16 p-8 rounded-xl border border-[var(--color-border)] dark:border-[#333] bg-[var(--color-beige)]/30 dark:bg-transparent">
      <h2 class="text-xl font-bold font-[var(--font-serif)] text-[var(--color-charcoal)] dark:text-[var(--color-cream)] mb-6 text-center">知识体系</h2>
      <div class="space-y-4 text-sm leading-relaxed">
        <div class="flex flex-col md:flex-row gap-4 justify-center text-center">
          <div class="flex-1 p-4 rounded-lg bg-white dark:bg-gray-900 border border-[var(--color-border)] dark:border-[#333]">
            <p class="font-semibold text-[var(--color-charcoal)] dark:text-[var(--color-cream)] mb-1">📖 架构分析</p>
            <p class="text-[var(--color-muted)] text-xs">理解 "是什么"<br/>生产级架构全貌</p>
          </div>
          <div class="text-[var(--color-muted)] self-center text-2xl hidden md:block">→</div>
          <div class="flex-1 p-4 rounded-lg bg-white dark:bg-gray-900 border border-[var(--color-border)] dark:border-[#333]">
            <p class="font-semibold text-[var(--color-charcoal)] dark:text-[var(--color-cream)] mb-1">🛠️ 动手实践</p>
            <p class="text-[var(--color-muted)] text-xs">理解 "怎么做"<br/>12 步渐进实现</p>
          </div>
          <div class="text-[var(--color-muted)] self-center text-2xl hidden md:block">→</div>
          <div class="flex-1 p-4 rounded-lg bg-white dark:bg-gray-900 border border-[var(--color-border)] dark:border-[#333]">
            <p class="font-semibold text-[var(--color-charcoal)] dark:text-[var(--color-cream)] mb-1">🔬 深度笔记</p>
            <p class="text-[var(--color-muted)] text-xs">理解 "为什么"<br/>教学 vs 生产对照</p>
          </div>
        </div>
        <p class="text-center text-xs text-[var(--color-muted)] pt-2">
          📝 补充资料贯穿其中，填补主题空白（Bootstrap / 并发 / MCP / 终端 / 性能）
        </p>
      </div>
    </div>

    <!-- Footer -->
    <footer class="text-center text-sm text-[var(--color-muted)] pt-8 border-t border-[var(--color-border)] dark:border-[#333]">
      <p>架构分析 · 动手实践 · 深度笔记 · 补充资料</p>
      <p class="mt-1"><a href="https://github.com/llwanghong/claude-code-universe" class="text-[var(--color-terracotta)] hover:underline">GitHub 仓库</a> · 持续更新</p>
    </footer>
  </main>
</BaseLayout>
