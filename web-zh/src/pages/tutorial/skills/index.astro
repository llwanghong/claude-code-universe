---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const skills = [
  { name: 'agent-builder', title: 'Agent Builder', desc: '构建自定义 Agent 的完整指南 — 从定义到部署' },
  { name: 'code-review', title: 'Code Review', desc: '代码审查 Agent 的配置与使用' },
  { name: 'mcp-builder', title: 'MCP Builder', desc: '构建 MCP 服务器的模板与指南' },
  { name: 'pdf', title: 'PDF', desc: 'PDF 文件处理技能' },
];
---

<BaseLayout title="技能 — learn-claude-code" description="">
  <main class="max-w-4xl mx-auto px-4 md:px-8 py-12 md:py-20">
    <a href="/claude-code-universe/tutorial/" class="text-sm text-[var(--color-muted)] hover:text-[var(--color-terracotta)] no-underline mb-4 inline-block">← 动手实践</a>
    <h1 class="text-3xl font-bold font-[var(--font-serif)] text-[var(--color-charcoal)] dark:text-[var(--color-cream)] mb-4">🎯 内置技能</h1>
    <p class="text-lg text-[var(--color-muted)] mb-2">learn-claude-code 自带的 4 个 Skill 示例</p>
    <p class="text-sm text-[var(--color-muted)] mb-10">每个 Skill 是一个独立的 <code class="text-xs bg-gray-100 dark:bg-gray-800 px-1 rounded">SKILL.md</code> 文件，展示了两阶段加载模式（元数据在 system prompt，完整内容在 tool_result 按需加载）。</p>

    <div class="space-y-4">
      {skills.map(s => (
        <div class="p-5 rounded-lg border border-[var(--color-border)] dark:border-[#333]">
          <h3 class="font-semibold text-[var(--color-charcoal)] dark:text-[var(--color-cream)] mb-2">🎯 {s.title}</h3>
          <p class="text-sm text-[var(--color-muted)] mb-3">{s.desc}</p>
          <div class="flex gap-3 text-xs">
            <a href={`https://github.com/shareAI-lab/learn-claude-code/blob/main/skills/${s.name}/SKILL.md`} class="text-[var(--color-terracotta)] hover:underline">📄 查看 SKILL.md</a>
            <span class="text-[var(--color-muted)]">skills/{s.name}/</span>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-8 p-4 rounded-lg border border-[var(--color-border)] dark:border-[#333]">
      <p class="text-sm text-[var(--color-muted)]">
        💡 <strong>两阶段加载模式</strong>：启动时只注入 skill 元数据（~100 tokens/skill），模型在需要时调用 <code class="text-xs bg-gray-100 dark:bg-gray-800 px-1 rounded">Skill(name)</code> 加载完整内容。这是 "不要把所有东西塞进 system prompt" 的最佳实践。
      </p>
    </div>
  </main>
</BaseLayout>
