---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CloudArchitectureDiagram from '../../components/cloud/CloudArchitectureDiagram.tsx';
import ExecutionPlaneDiagram from '../../components/cloud/ExecutionPlaneDiagram.tsx';
import PermissionFlowDiagram from '../../components/cloud/PermissionFlowDiagram.tsx';
import SecurityLayersDiagram from '../../components/cloud/SecurityLayersDiagram.tsx';
---

<BaseLayout title="云端 Claude Code — Demo" description="交互式架构图演示">
  <main style="background: #faf9f7; min-height: 100vh; padding: 64px 24px;">
    <div style="max-width: 960px; margin: 0 auto;">

      <!-- Simple header -->
      <div style="textAlign: center; marginBottom: 48px;">
        <div style="fontSize: 11px; fontWeight: 700; letterSpacing: 0.12em; color: '#8b8680'; marginBottom: 12px;">
          ENTERPRISE DESIGN · v1.0
        </div>
        <h1 style="fontSize: 'clamp(28px, 4vw, 40px)'; fontWeight: 800; color: '#1a1917'; margin: '0 0 12px'; letterSpacing: '-0.02em';">
          Cloud Claude Code
        </h1>
        <p style="fontSize: 16px; color: '#8b8680'; maxWidth: 560px; margin: '0 auto 28px'; lineHeight: 1.6;">
          Based on 18-chapter Claude Code source architecture study.
          Enterprise-grade cloud agent platform design.
        </p>
        <div style="display: flex; gap: 10px; justifyContent: center;">
          <a href="/claude-code-universe/cloud-claude-code/" style="padding: '8px 20px'; background: '#1a1917'; color: '#fff'; borderRadius: 8; textDecoration: none; fontSize: 13px; fontWeight: 600;">
            View Docs →
          </a>
          <a href="https://github.com/llwanghong/claude-code-universe/tree/main/cloud-claude-code" style="padding: '8px 20px'; background: '#fff'; color: '#1a1917'; border: '1px solid #e8e5e1'; borderRadius: 8; textDecoration: none; fontSize: 13px; fontWeight: 600;">
            GitHub
          </a>
        </div>
      </div>

      <CloudArchitectureDiagram client:load />
      <div style="height: 48px" />
      <ExecutionPlaneDiagram client:load />
      <div style="height: 48px" />
      <PermissionFlowDiagram client:load />
      <div style="height: 48px" />
      <SecurityLayersDiagram client:load />

    </div>
  </main>
</BaseLayout>
