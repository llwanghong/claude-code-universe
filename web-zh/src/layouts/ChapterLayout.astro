---
import BaseLayout from './BaseLayout.astro'
import Sidebar from '../components/Sidebar.astro'
import TableOfContents from '../components/TableOfContents.astro'
import ChapterNav from '../components/ChapterNav.astro'
import type { Chapter } from '../book.config'

interface Props {
  title: string
  slug: string
  chapterNumber: number
  headings: { depth: number; slug: string; text: string }[]
  prev: Chapter | null
  next: Chapter | null
  part?: string
}

const { title, chapterNumber, headings, prev, next, part } = Astro.props
---

<BaseLayout title={title}>
  <div class="flex min-h-screen">
    <Sidebar currentChapter={chapterNumber} />
    <main class="flex-1 min-w-0">
      <div class="mx-auto max-w-3xl px-6 py-12 lg:px-8 xl:px-12">
        <!-- Chapter header -->
        {part && <p class="text-sm font-medium text-blue-500 dark:text-blue-400 mb-2">{part}</p>}
        <h1 class="text-3xl font-bold tracking-tight text-gray-900 dark:text-white sm:text-4xl mb-2">
          第 {chapterNumber} 章
        </h1>
        <p class="text-xl text-gray-600 dark:text-gray-400 mb-10">{title}</p>

        <!-- Chapter content -->
        <article>
          <slot />
        </article>

        <ChapterNav prev={prev} next={next} />
      </div>
    </main>
    <TableOfContents headings={headings} />
  </div>
</BaseLayout>
