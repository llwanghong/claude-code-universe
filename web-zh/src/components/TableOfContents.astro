---
interface Props { headings: { depth: number; slug: string; text: string }[] }
const { headings } = Astro.props
const items = headings.filter(h => h.depth >= 2 && h.depth <= 3)
---

{items.length > 0 && (
  <aside class="hidden xl:block w-56 flex-shrink-0 sticky top-0 h-screen overflow-y-auto">
    <div class="p-6">
      <h3 class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-3">本页目录</h3>
      <nav id="toc-nav">
        <ul class="space-y-1 text-sm">
          {items.map(h => (
            <li>
              <a
                href={`#${h.slug}`}
                class={`block py-1 text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors ${
                  h.depth === 3 ? 'pl-3' : ''
                }`}
              >
                {h.text}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </div>
  </aside>
)}
